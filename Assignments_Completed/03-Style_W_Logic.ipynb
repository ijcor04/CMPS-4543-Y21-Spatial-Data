from pathlib import Path

cwd = Path.cwd()

target = cwd.parent / "data" / "countries.geojson"
print(target)

exists = target.exists()
print("\nDoes file exist?")
print(exists)

assert exists, (
    f"\n❌ ERROR: File not found:\n{target}\n"
    "Check spelling and folder structure."
)

import json
from rich import print
import folium



with open(target,"r") as f:
   data = json.load(f)
   
print(data["features"][0])
    
gj_type = data.get("type", None)
features = data.get("features", [])
print("GeoJSON type:", gj_type)
print("Feature count:", len(features))

assert gj_type == "FeatureCollection", f"❌ Expected FeatureCollection, got: {gj_type}"
assert len(features) > 0, "❌ FeatureCollection has zero features."




# Create an instance of a map to put data on
m = folium.Map(location=[0,0], zoom_start=3)
  
# Display map without changing colors
folium.GeoJson(
    data,
    name="world"
).add_to(m)
  
m

def style_function(feature):
    nm = feature["properties"]["ADMIN"].strip().upper()
    if nm and nm[0] >= "A" and nm[0] <= "M":
        return {"fillColor": "red", "color": "red", "fillOpacity": 0.6}
    else:
        return {"fillColor": "purple", "color": "purple", "fillOpacity": 0.6}

m2 = folium.Map(location=[0,0], zoom_start=3)
  
# Display map without changing colors
folium.GeoJson(
    data,
    name="world",
    style_function=style_function
).add_to(m2)
  
m2
